{
  "name": "api-server",
  "version": "1.0.0",
  "description": "Minimal API key server for BTH courses",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/src/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "tui": "tsx --env-file=.env tui/index.ts",
    "tui:prod": "tsx --env-file=.env.prod tui/index.ts",
    "tui:docker": "NODE_TLS_REJECT_UNAUTHORIZED=0 API_URL=https://localhost:8443 tsx --env-file=.env tui/index.ts",
    "clean": "rm -rf node_modules/ package-lock.json",
    "clean:all": "npm run clean && rm -rf dist/ coverage/ data/",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm test",
    "prepare": "husky"
  },
  "dependencies": {
    "@dbwebb/tui": "^1.3.0",
    "better-sqlite3": "^11.0.0",
    "express": "^5.0.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "swagger-ui-express": "^5.0.1",
    "yaml": "^2.9.0",
    "zod": "^3.23.0"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@vitest/coverage-v8": "^4.0.0",
    "eslint": "^9.0.0",
    "husky": "^9.1.7",
    "prettier": "^3.0.0",
    "supertest": "^7.2.2",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.0.0"
  }
}
