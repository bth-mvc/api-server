# =============================================================================
# MÅSTE SÄTTAS — inga defaults
# =============================================================================
ADMIN_TOKEN=change-this-to-a-long-random-string
SERVICE_TOKEN=change-this-to-another-long-random-string
DOMAIN=api.example.com          # prod: api.example.com  |  lokalt: localhost

# =============================================================================
# DEFAULTS — kan lämnas som de är
# =============================================================================
PORT=5000
DB_PATH=./data/keys.db
NODE_ENV=production              # development ger utökad loggning

# =============================================================================
# DOCKER — valfritt, ändra om port 80/443 är upptagna
# =============================================================================
# HTTP_PORT=8081
# HTTPS_PORT=8443
# CADDYFILE=Caddyfile.local      # self-signed cert via Caddys egna CA (lokal testning)
